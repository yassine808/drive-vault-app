{
  "name": "vault",
  "version": "2.0.0",
  "description": "Encrypted password & notes vault",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev":   "electron . --dev",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.vault.app",
    "productName": "Vault",
    "icon": "assets/icon",
    "mac":   { "category": "public.app-category.productivity", "icon": "assets/icon.png" },
    "win":   { "target": "nsis", "icon": "assets/icon.ico" },
    "linux": { "target": "AppImage", "icon": "assets/icon.png" }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "crypto-js":             "^4.2.0",
    "googleapis":            "^140.0.0",
    "speakeasy":             "^2.0.0",
    "uuid":                  "^9.0.0"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
