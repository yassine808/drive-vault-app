{
  "name": "vault",
  "version": "2.0.0",
  "description": "Encrypted password & notes vault",
  "main": "dist/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "vite --clearScreen false & tsc --watch & electron .",
    "start": "vite build && tsc && tsc -p tsconfig.preload.json && electron .",
    "build:all": "vite build && tsc",
    "build:mac": "npm run build:all && electron-builder --mac",
    "build:win": "npm run build:all && electron-builder --win",
    "build:linux": "npm run build:all && electron-builder --linux"
  },
  "build": {
    "appId": "com.vault.app",
    "productName": "Vault",
    "icon": "assets/icon",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.9.1",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
